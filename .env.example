# Your Helius RPC API key for Solana data (get from helius.dev)
HELIUS_API_KEY="your_helius_api_key_here"

# The main URL for your Supabase project (from your project's API settings)
SUPABASE_URL="https://your-project-id.supabase.co"

# The public anonymous key for Supabase client-side requests (from your project's API settings)
SUPABASE_ANON_KEY="your_supabase_anon_key_here"

# The secret service role key for Supabase admin tasks. WARNING: NEVER expose this key on the client side!
SUPABASE_SERVICE_ROLE="your_supabase_service_role_key_here"

# The URL for the API server
API_URL="http://localhost:3001/api"